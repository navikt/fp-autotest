KAFKA_SCHEMA_REGISTRY_PASSWORD=kafka
KAFKA_TRUSTSTORE_PATH=/app/.modig/truststore.jks
KAFKA_KEYSTORE_PATH=/app/.modig/keystore.jks
KAFKA_CREDSTORE_PASSWORD=vtpvtp
KAFKA_BRUK_AIVEN_PROPERTY_LOKALT=true

##### Truststore global
NAV_TRUSTSTORE_PATH=/app/.modig/truststore.jks # Brukes i java base image, se 00-truststore.sh i fp-baseimages
NAV_TRUSTSTORE_PASSWORD=vtpvtp # Brukes i java base image, se 00-truststore.sh i fp-baseimages
JAVA_TOOL_OPTIONS=" -Djavax.net.ssl.trustStore=/app/.modig/truststore.jks -Djavax.net.ssl.trustStorePassword=vtpvtp" # Brukes for distroless image

